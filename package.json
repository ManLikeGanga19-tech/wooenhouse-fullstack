{
  "name": "wooden-houses-kenya",
  "private": true,
  "scripts": {
    "test:backend":  "dotnet test backend/WoodenHousesAPI.Tests/WoodenHousesAPI.Tests.csproj --no-restore --verbosity normal",
    "test:frontend": "cd frontend && npm test -- --passWithNoTests --forceExit",
    "test:e2e":      "cd frontend && npm run test:e2e",
    "test:all":      "npm run test:backend && npm run test:frontend && npm run test:e2e",
    "test:ci":       "npm run test:backend && npm run test:frontend"
  }
}
